# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# Die .env-Datei NICHT ins Git einchecken (siehe .gitignore).

# Token von @BotFather in Telegram (Pflicht, damit der Bot startet)
TELEGRAM_BOT_TOKEN=

# Deine Chat-ID (optional, aber empfohlen).
# Ist sie gesetzt, reagiert der Bot NUR auf diese Chat-ID.
TELEGRAM_CHAT_ID=

# OpenAI (OPTIONAL). Nur zum Verbessern von Texten/Anschreiben/Analyse.
# Ohne Key läuft alles lokal weiter. Der Key wird nie ausgegeben oder geloggt.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Indeed-Alert E-Mail-Import (OPTIONAL).
# Liest NUR dein eigenes Postfach per IMAP. Kein Indeed-Login, kein Scraping.
# Gmail/Outlook: i. d. R. App-Passwort nötig (2FA), nicht das normale Passwort.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX
EMAIL_FROM_FILTER=indeed
EMAIL_LOOKBACK_DAYS=3
EMAIL_MIN_SCORE_FOR_OPENAI=60
EMAIL_MIN_SCORE_FOR_TELEGRAM=75

# Automatischer E-Mail-Import im laufenden Telegram-Bot (Option A).
# Solange der Bot läuft, prüft er alle X Minuten das Postfach und pusht neue Treffer.
EMAIL_AUTO_IMPORT_ENABLED=true
EMAIL_AUTO_IMPORT_INTERVAL_MINUTES=30
EMAIL_AUTO_IMPORT_INCLUDE_SEEN=false
